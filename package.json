{
  "name": "kaikaio-booking-server",
  "version": "1.0.0",
  "description": "Kaikaio-Booking 服务端项目",
  "private": true,
  "egg": {
    "declarations": true
  },
  "dependencies": {
    "csvtojson": "^2.0.14",
    "dayjs": "^1.11.19",
    "egg": "^3.34.0",
    "egg-cors": "^3.0.1",
    "egg-jwt": "^3.1.7",
    "egg-mysql": "^5.0.0",
    "egg-scripts": "^3.1.0",
    "mkdirp": "^1.0.4",
    "node-csv": "^0.1.2"
  },
  "devDependencies": {
    "autod": "^3.0.1",
    "autod-egg": "^1.1.0",
    "cross-env": "^10.1.0",
    "egg-bin": "^6.13.0",
    "egg-ci": "^2.2.0",
    "egg-mock": "^5.15.2",
    "eslint": "^8.57.0",
    "eslint-config-egg": "^14.1.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "start": "egg-scripts start --daemon --title=egg-server-kaikaio-booking-server",
    "stop": "egg-scripts stop --title=egg-server-kaikaio-booking-server",
    "dev": "egg-bin dev",
    "debug": "egg-bin debug",
    "test": "npm run lint -- --fix && npm run test-local",
    "test-local": "cross-env EGG_SERVER_ENV=unittest egg-bin test",
    "cov": "cross-env EGG_SERVER_ENV=unittest egg-bin cov",
    "lint": "eslint .",
    "ci": "npm run lint && npm run cov",
    "autod": "autod"
  },
  "ci": {
    "version": "10"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "author": "Kaikaio",
  "license": "MIT"
}
