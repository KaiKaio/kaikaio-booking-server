{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "outDir": "./app",
    "rootDir": "./src",
    "ignoreDeprecations": "5.0",
    "types": ["node", "mocha", "power-assert"]
  },
  "include": [
    "src/**/*",
    "typings/**/*.ts",
    "typings/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "app",
    "logs",
    "run",
    "coverage",
    "test"
  ],
  "ts-node": {
    "transpileOnly": true,
    "files": true
  }
}
